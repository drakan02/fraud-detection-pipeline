{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Real-time Fraud Detection Pipeline — fraud rate, ML latency, throughput, data quality",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "type": "stat",
      "title": "Fraud Alerts (Total)",
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" },
        "overrides": []
      },
      "targets": [{
        "expr": "sum(increase(fraud_predictions_total{is_fraud=\"true\"}[5m]))",
        "legendFormat": "Fraud Alerts (5m)",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "type": "stat",
      "title": "Fraud Rate (%)",
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [{
        "expr": "100 * sum(rate(fraud_predictions_total{is_fraud=\"true\"}[5m])) / sum(rate(fraud_predictions_total[5m]))",
        "legendFormat": "Fraud Rate",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "type": "stat",
      "title": "ML Latency p95 (ms)",
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])) by (le)) * 1000",
        "legendFormat": "p95 Latency",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "type": "stat",
      "title": "Malformed Messages",
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [{
        "expr": "sum(increase(fraud_pipeline_malformed_messages_total[5m]))",
        "legendFormat": "Malformed (5m)",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "type": "stat",
      "title": "Active Model Version",
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" },
        "overrides": []
      },
      "targets": [{
        "expr": "fraud_model_info",
        "legendFormat": "{{version}}",
        "datasource": "Prometheus"
      }]
    },
    {
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "type": "timeseries",
      "title": "Fraud Alerts Rate (CEP vs ML)",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(fraud_predictions_total{is_fraud=\"true\"}[1m]))",
          "legendFormat": "ML Fraud Alerts/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=\"/predict\"}[1m]))",
          "legendFormat": "Total Predictions/s",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "type": "timeseries",
      "title": "ML Inference Latency Distribution",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=\"/predict\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "type": "timeseries",
      "title": "Data Quality — Valid vs Malformed Messages",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Malformed/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(fraud_pipeline_valid_messages_total[1m]))",
          "legendFormat": "Valid/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum(rate(fraud_pipeline_malformed_messages_total[1m]))",
          "legendFormat": "Malformed/s",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "type": "timeseries",
      "title": "Model Server Request Throughput",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=\"/predict\", status_code=~\"2..\"}[1m]))",
          "legendFormat": "Success/s",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=\"/predict\", status_code=~\"5..\"}[1m]))",
          "legendFormat": "Errors/s",
          "datasource": "Prometheus"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["fraud", "flink", "kafka", "ml"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Fraud Detection Pipeline",
  "uid": "fraud-pipeline-v1",
  "version": 1
}
